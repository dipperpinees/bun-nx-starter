POSTGRES_HOST_PORT=5342
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bun_nx

# API
PORT=3000
WEB_ORIGIN=http://localhost:4200
AUTHENTIK_ISSUER_URL=http://localhost:9100/application/o/bun-nx/
AUTHENTIK_CLIENT_ID=web-client

# Web (Vite)
VITE_API_URL=http://localhost:3000
VITE_AUTHENTIK_ISSUER_URL=http://localhost:9100/application/o/bun-nx/
VITE_AUTHENTIK_CLIENT_ID=web-client
VITE_AUTHENTIK_REDIRECT_URI=http://localhost:4200/auth/callback
VITE_AUTHENTIK_POST_LOGOUT_REDIRECT_URI=http://localhost:4200
VITE_AUTHENTIK_SCOPE=openid profile email

# Authentik
AUTHENTIK_HOST_PORT=9100
